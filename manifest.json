{
  "name": "Loglinkr",
  "short_name": "Loglinkr",
  "description": "Plant operations + IATF compliance for Indian SME manufacturers",
  "start_url": "/app",
  "scope": "/app",
  "display": "standalone",
  "orientation": "portrait",
  "background_color": "#ffffff",
  "theme_color": "#0d9488",
  "categories": ["productivity", "business"],
  "icons": [
    { "src": "/icon-96.png", "sizes": "96x96", "type": "image/png", "purpose": "any" },
    { "src": "/icon-192.png", "sizes": "192x192", "type": "image/png", "purpose": "any" },
    { "src": "/icon-512.png", "sizes": "512x512", "type": "image/png", "purpose": "any" },
    { "src": "/icon-192-maskable.png", "sizes": "192x192", "type": "image/png", "purpose": "maskable" },
    { "src": "/icon-512-maskable.png", "sizes": "512x512", "type": "image/png", "purpose": "maskable" }
  ],
  "shortcuts": [
    { "name": "Chat", "url": "/app?tab=chat", "description": "Open team chat" },
    { "name": "Action Hub", "url": "/app?tab=actions", "description": "Pending tasks" },
    { "name": "Production", "url": "/app?tab=production", "description": "Stage log" }
  ],
  "share_target": {
    "action": "/app?sharetarget=1",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url",
      "files": [
        { "name": "bill", "accept": ["image/jpeg", "image/png", "image/webp", "image/*", "application/pdf"] }
      ]
    }
  }
}
